{
  "name": "tutor-whatsapp-saas",
  "version": "1.0.0",
  "description": "WhatsApp AI Assistant + Tutor Admin Dashboard for Sri Lankan tuition classes",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "nodemon server/index.js",
    "dev:client": "cd client && npm run dev",
    "build:client": "cd client && npm run build",
    "start": "node server/index.js",
    "setup": "node server/db/migrate.js",
    "seed": "node server/db/seed.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.77.0",
    "qrcode": "^1.5.4",
    "sql.js": "^1.14.1",
    "whatsapp-web.js": "^1.26.1-alpha.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.7"
  }
}
