# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3001
NODE_ENV=production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
CLIENT_URL=http://YOUR_SERVER_IP

# ==========================================
# AI CONFIGURATION — OpenAI Only
# ==========================================
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_API_KEY_HERE
OPENAI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=800
AI_CACHE_EXPIRY=24
USE_MOCK_AI=false

# ==========================================
# WHATSAPP & DATABASE
# ==========================================
WA_SESSION_PATH=./.wwebjs_auth
# Your WhatsApp admin phone number (94 format)
ADMIN_PHONE=94XXXXXXXXXX

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
DATABASE_URL=postgresql://postgres.your-project:PASSWORD@region.pooler.supabase.com:6543/postgres

# ==========================================
# Master Security
# ==========================================
REGISTRATION_KEY=YOUR_SECRET_KEY_HERE
